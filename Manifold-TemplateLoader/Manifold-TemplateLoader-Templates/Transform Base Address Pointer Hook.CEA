<< Header >>

[ENABLE]

// aobScanModule(<< HookNameParsed >>,<< Module >>,<< AoBStr >>)
ManifoldScanModule(<< HookNameParsed >>,<< Module >>,<< AoBStr >>)
<< Alloc >>

ManifoldAssert(<< HookNameParsed >>,<< OriginalBytes >>)

label(o_<< HookName >> r_<< HookName >>)
label(<< HookName >>Ptr)
label(<< HookName >>Offsets SavedPositionFlt BackupPositionFlt)

n_<< HookName >>:
  mov [<< HookName >>Ptr],<< BaseAddressRegister >>

o_<< HookName >>:
<< OriginalOpcodes >>
  jmp r_<< HookName >>
  
<< HookName >>Ptr:
 << PointerType >> 0
<< HookName >>Offsets:
 dd 08
 dd 0C
 dd 10
SavedPositionFlt:
 dd (float)0
 dd (float)0
 dd (float)0
BackupPositionFlt:
 dd (float)0
 dd (float)0
 dd (float)0

<< HookNameParsed >><< AoBOffset >>:
  << JumpType >> n_<< HookName >>
  << NopPadding >>
r_<< HookName >>:
registersymbol(<< HookNameParsed >> << HookName >>Ptr)
registersymbol(<< HookName >>Offsets SavedPositionFlt BackupPositionFlt)

[DISABLE]

<< HookNameParsed >><< AoBOffset >>:
  db << OriginalBytes >>

unregisterSymbol(*)
dealloc(*)