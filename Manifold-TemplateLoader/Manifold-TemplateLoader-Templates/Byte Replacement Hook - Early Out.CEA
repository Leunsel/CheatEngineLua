<< Header >>

[ENABLE]

// aobScanModule(<< HookNameParsed >>,<< Module >>,<< AoBStr >>)
ManifoldScanModule(<< HookNameParsed >>,<< Module >>,<< AoBStr >>)

ManifoldAssert(<< HookNameParsed >>,<< OriginalBytes >>)

<< HookNameParsed >><< AoBOffset >>:
  db C3

registersymbol(<< HookNameParsed >>)

[DISABLE]

<< HookNameParsed >><< AoBOffset >>:
  db << OriginalBytes >>

unregisterSymbol(*)